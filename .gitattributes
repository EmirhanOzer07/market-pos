# Tüm metin dosyaları repo'da LF ile saklanır
* text=auto eol=lf

# Windows scriptleri CRLF gerektirir
*.cmd  text eol=crlf
*.bat  text eol=crlf

# Açık metin dosyaları
*.java       text eol=lf
*.xml        text eol=lf
*.properties text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.md         text eol=lf
*.sql        text eol=lf
*.json       text eol=lf
*.txt        text eol=lf
*.sh         text eol=lf
/mvnw        text eol=lf

# İkili dosyalar — satır sonu dönüşümü yok, diff yok
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.jar   binary
*.zip   binary
*.exe   binary
*.dll   binary
*.class binary
*.mv.db binary
